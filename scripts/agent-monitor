#!/usr/bin/env bash
set -euo pipefail

PORT="${AGENT_MONITOR_PORT:-8765}"
HOST="${AGENT_MONITOR_HOST:-127.0.0.1}"

usage() {
  cat <<'USAGE'
agent-monitor: static local call helper for the macOS AgentMonitor widget

Usage:
  scripts/agent-monitor <agent-id> <green|yellow|red> [message] [name] [terminal-tag]
  scripts/agent-monitor list
  scripts/agent-monitor clear

Examples:
  scripts/agent-monitor hermes-main yellow "running tests" "Hermes main"
  scripts/agent-monitor codex-1 red "waiting for approval"
  scripts/agent-monitor hermes-main green "finished"

Environment:
  AGENT_MONITOR_PORT defaults to 8765
  AGENT_MONITOR_HOST defaults to 127.0.0.1
  AGENT_MONITOR_TERMINAL_TAG optionally supplies metadata.terminal_tag
  AGENT_MONITOR_CWD optionally supplies metadata.cwd; defaults to current directory
USAGE
}

if [[ $# -lt 1 ]]; then usage; exit 64; fi

case "$1" in
  list)
    curl -fsS "http://${HOST}:${PORT}/agents"
    ;;
  clear)
    curl -fsS -X DELETE "http://${HOST}:${PORT}/agents"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    if [[ $# -lt 2 ]]; then usage; exit 64; fi
    AGENT_ID="$1"
    STATE="$2"
    MESSAGE="${3:-}"
    NAME="${4:-$AGENT_ID}"
    case "$STATE" in green|yellow|red) ;; *) echo "state must be green, yellow, or red" >&2; exit 64 ;; esac
    TERMINAL_TAG="${5:-${AGENT_MONITOR_TERMINAL_TAG:-}}"
    CWD="${AGENT_MONITOR_CWD:-$PWD}"
    payload=$(python3 - "$STATE" "$MESSAGE" "$NAME" "$TERMINAL_TAG" "$CWD" <<'PY'
import json
import sys
state, message, name, terminal_tag, cwd = sys.argv[1:6]
payload = {"state": state, "message": message, "name": name}
metadata = {}
if terminal_tag:
    metadata["terminal_tag"] = terminal_tag
if cwd:
    metadata["cwd"] = cwd
if metadata:
    payload["metadata"] = metadata
print(json.dumps(payload, separators=(",", ":")))
PY
)
    curl -fsS \
      -X POST \
      -H 'Content-Type: application/json' \
      -d "$payload" \
      "http://${HOST}:${PORT}/agents/${AGENT_ID}"
    ;;
esac
